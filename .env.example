# Google OAuth credentials — required to connect a Google Calendar account.
# Create at console.cloud.google.com → APIs & Services → Credentials →
# OAuth client ID → "Web application". Enable the Google Calendar API, and set
# the authorized redirect URI to:
#   http://localhost:3000/api/oauth/google/callback
# Then copy this file to .env.local and fill in the values (see README).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Todoist API token (read-only sync). Todoist → Settings → Integrations →
# Developer → copy the API token. Todoist connects automatically on boot.
TODOIST_API_TOKEN=your-todoist-api-token
